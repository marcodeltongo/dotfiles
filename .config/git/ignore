# ==========================================================
# Global gitignore — applies to all repositories
# XDG path: ~/.config/git/ignore (picked up automatically)
# ==========================================================

# ── macOS ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# ── Editors ────────────────────────────────────────────────
# Zed
.zed/

# Helix
# (no project-level artifacts)

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# Vim / Neovim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# ── Claude Code ────────────────────────────────────────────
**/.claude/settings.local.json
# Runtime/session data — never commit
.claude/projects/
.claude/cache/
.claude/backups/
.claude/history.jsonl
.claude/stats-cache.json
.claude/todos/
.claude/tasks/
.claude/session-env/
.claude/shell-snapshots/
.claude/telemetry/
.claude/downloads/
.claude/file-history/
.claude/debug/
.claude/ide/
.claude/statsig/
.claude/mcp-needs-auth-cache.json
# Worktrees — ignore at all levels (project + global)
**/.claude/worktrees/

# ── Node / pnpm ────────────────────────────────────────────
node_modules/
.pnpm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env
dist/
*.egg-info/

# ── Rust ───────────────────────────────────────────────────
target/

# ── Go ─────────────────────────────────────────────────────
*.test
*.out

# ── Misc ───────────────────────────────────────────────────
*.log
*.tmp
*.swp
*.bak
.env.local
.env.*.local
