{
  "env": {
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(git status*)",
      "Bash(rtk git status*)",
      "Bash(git log*)",
      "Bash(rtk git log*)",
      "Bash(git diff*)",
      "Bash(rtk git diff*)",
      "Bash(git branch*)",
      "Bash(rtk git branch*)",
      "Bash(git show*)",
      "Bash(rtk git show*)",
      "Bash(git stash list*)",
      "Bash(rtk git stash list*)",
      "Bash(git fetch*)",
      "Bash(rtk git fetch*)",
      "Bash(git remote*)",
      "Bash(rtk git remote*)",
      "Bash(git tag*)",
      "Bash(rtk git tag*)",
      "Bash(git worktree*)",
      "Bash(rtk git worktree*)",
      "Bash(gh pr list*)",
      "Bash(rtk gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(rtk gh pr view*)",
      "Bash(gh pr status*)",
      "Bash(rtk gh pr status*)",
      "Bash(gh pr checks*)",
      "Bash(rtk gh pr checks*)",
      "Bash(gh issue list*)",
      "Bash(rtk gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(rtk gh issue view*)",
      "Bash(gh issue status*)",
      "Bash(rtk gh issue status*)",
      "Bash(gh repo view*)",
      "Bash(rtk gh repo view*)",
      "Bash(gh repo list*)",
      "Bash(rtk gh repo list*)",
      "Bash(gh run list*)",
      "Bash(rtk gh run list*)",
      "Bash(gh run view*)",
      "Bash(rtk gh run view*)",
      "Bash(gh release list*)",
      "Bash(rtk gh release list*)",
      "Bash(gh release view*)",
      "Bash(rtk gh release view*)",
      "Bash(gh auth status*)",
      "Bash(rtk gh auth status*)",
      "Bash(npm test*)",
      "Bash(ls*)",
      "Bash(eza*)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(command -v *)",
      "Bash(cat *)",
      "Bash(bat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(echo *)",
      "Bash(date*)",
      "Bash(env)",
      "Bash(printenv*)",
      "Bash(mise current*)",
      "Bash(mise list*)",
      "Bash(mise run*)",
      "Bash(rtk mise run*)",
      "Bash(mise ls *)",
      "Bash(git --git-dir=/Users/marco/.dotfiles/ --work-tree=/Users/marco ls-files:*)",
      "Bash(rtk git --git-dir=/Users/marco/.dotfiles/ --work-tree=/Users/marco ls-files:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(python3 --version)",
      "Bash(bun --version)",
      "Bash(go version)",
      "Bash(rustc --version)",
      "Bash(pnpm --version)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(swift build*)",
      "Bash(swift test*)",
      "Bash(swift package*)",
      "WebFetch(domain:*.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gitlab.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:vitejs.dev)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:docs.agno.com)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:*.jdx.dev)",
      "WebFetch(domain:ghostty.org)"
    ],
    "deny": [
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(sudo *)",
      "Bash(chmod*)",
      "Bash(chown*)",
      "mcp__ccd_session_mgmt__archive_session"
    ],
    "defaultMode": "default"
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [],
    "SessionEnd": []
  },
  "worktree": {
    "symlinkDirectories": [
      ".cache"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "terraform-code-generation@hashicorp": true,
    "terrashark@terrashark": true,
    "deploy-on-aws@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    },
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    },
    "terrashark": {
      "source": {
        "source": "github",
        "repo": "LukasNiessen/terrashark"
      }
    }
  },
  "viewMode": "default",
  "language": "italian",
  "effortLevel": "high",
  "tui": "fullscreen",
  "theme": "dark-ansi",
  "editorMode": "normal",
  "autoCompactEnabled": true,
  "fileCheckpointingEnabled": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "skipWorkflowUsageWarning": true
}
