          },
          "Vue.js": {
            "format_on_save": "on",
            "prettier": {
              "allowed": false
            },
            "formatter": [
              {
                "language_server": {
                  "name": "oxfmt"
                }
              }
            ]
          },
          "YAML": {
            "format_on_save": "on",
            "prettier": {
              "allowed": false
